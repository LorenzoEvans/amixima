{
  "@context": {
    "mo": "http://purl.org/ontology/mo/",
    "aufx": "http://purl.org/ontology/aufx-o/",
    "dc": "http://purl.org/dc/elements/1.1/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Soundcourse": "mo:Workflow",
    "sequence": {
      "@id": "mo:workflow_step",
      "@container": "@list"
    },
    "mo:sampleRate": {
      "@type": "xsd:float"
    }
  },
  "@id": "amixima:sc:example-soft-compress",
  "@type": "mo:Workflow",
  "dc:title": "Soft Compress",
  "dc:description": "Light peak control.",
  "mo:sampleRate": 44100.0,
  "creator": "Amixima",
  "sequence": [
    {
      "aufx:type": "aufx:Compressor",
      "aufx:parameters": {
        "aufx:threshold": -16.0,
        "aufx:ratio": 2.5
      }
    }
  ]
}

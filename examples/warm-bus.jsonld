{
  "@context": {
    "mo": "http://purl.org/ontology/mo/",
    "aufx": "http://purl.org/ontology/aufx-o/",
    "dc": "http://purl.org/dc/elements/1.1/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Soundcourse": "mo:Workflow",
    "sequence": {
      "@id": "mo:workflow_step",
      "@container": "@list"
    },
    "mo:sampleRate": {
      "@type": "xsd:float"
    }
  },
  "@id": "amixima:sc:example-warm-bus",
  "@type": "mo:Workflow",
  "dc:title": "Warm Bus",
  "dc:description": "Gentle gain, EQ, and compression for WAV batch processing.",
  "mo:sampleRate": 44100.0,
  "creator": "Amixima",
  "sequence": [
    {
      "aufx:type": "aufx:Gain",
      "aufx:parameters": {
        "aufx:gainDb": 1.5
      }
    },
    {
      "aufx:type": "aufx:EQ",
      "aufx:parameters": {
        "aufx:frequency": 800.0,
        "aufx:gain": 2.0
      }
    },
    {
      "aufx:type": "aufx:Compressor",
      "aufx:parameters": {
        "aufx:threshold": -18.0,
        "aufx:ratio": 3.0
      }
    }
  ]
}
